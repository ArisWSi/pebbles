---
import { getCollection } from 'astro:content'
import SerifLayout from '../../layouts/SerifLayout.astro'

export async function getStaticPaths() {
  const posts = await getCollection('posts', ({ data }) => data.section === 'serif')
  return posts.map(post => ({
    params: { slug: post.id },
    props: { post },
  }))
}

const { post } = Astro.props
const { title, date } = post.data
const { Content } = await post.render()
---

<SerifLayout title={title} date={date}>
  <Content />
</SerifLayout>
